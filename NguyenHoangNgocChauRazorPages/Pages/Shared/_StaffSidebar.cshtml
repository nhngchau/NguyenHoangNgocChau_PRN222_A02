@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    string active(string prefix) => currentPage.StartsWith(prefix) ? "active" : "";
}

<aside class="staff-sidebar">
    <div class="side-card">
        <div class="side-title">Staff Workspace</div>
        <nav class="side-nav">
            <a asp-page="/Staff/News/Index" class="@active("/Staff/News")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 0-1.5 2zM9 7h10M9 11h10M9 15h6"/></svg>
                News Articles
            </a>
            <a asp-page="/Staff/Categories/Index" class="@active("/Staff/Categories")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                Categories
            </a>
            <a asp-page="/Staff/History/Index" class="@active("/Staff/History")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="12 8 12 12 14 14"/><path d="M3.05 11a9 9 0 1 1 .5 4m-.5 5v-5h5"/></svg>
                History
            </a>
            <a asp-page="/Staff/Profile/Index" class="@active("/Staff/Profile")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                My Profile
            </a>
        </nav>
    </div>
</aside>
