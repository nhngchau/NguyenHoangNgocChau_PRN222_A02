@page
@model NguyenHoangNgocChauRazorPages.Pages.Admin.Reports.IndexModel
@{ ViewData["Title"] = "News Report"; }

<h1>News Report</h1>
@if (TempData["Error"] is string error) { <div class="alert alert-danger">@error</div> }

<form method="get" class="row g-3 mb-4">
    <div class="col-md-3"><label asp-for="StartDate" class="form-label"></label><input asp-for="StartDate" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="EndDate" class="form-label"></label><input asp-for="EndDate" class="form-control" /></div>
    <div class="col-auto align-self-end"><button type="submit" class="btn btn-primary">Generate report</button></div>
</form>

@if (Model.HasFilter)
{
    <p><strong>Total news: @Model.Articles.Count</strong></p>
    <div class="table-responsive"><table class="table table-striped align-middle">
        <thead><tr><th>ID</th><th>Title</th><th>Headline</th><th>Category</th><th>Created Date</th><th>Created By</th><th>Status</th></tr></thead>
        <tbody>
        @foreach (var article in Model.Articles)
        {
            <tr>
                <td>@article.NewsArticleID</td><td>@article.NewsTitle</td><td>@article.Headline</td>
                <td>@(article.Category?.CategoryName ?? "Uncategorized")</td><td>@article.CreatedDate?.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@(article.CreatedBy?.AccountName ?? "N/A")</td><td>@(article.NewsStatus == true ? "Active" : "Inactive")</td>
            </tr>
        }
        </tbody>
    </table></div>
}
else
{
    <p>Select a start date and/or end date to generate the report.</p>
}
