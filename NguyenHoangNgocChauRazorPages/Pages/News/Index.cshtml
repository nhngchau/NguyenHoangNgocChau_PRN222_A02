@page
@model NguyenHoangNgocChauRazorPages.Pages.News.IndexModel
@{
    ViewData["Title"] = "Active News";
}

@section Styles {
<style>
    /* ══════════════════════════════════════════
       Public / Lecturer News Feed Styles
    ══════════════════════════════════════════ */

    .news-feed-header {
        margin-bottom: 2rem;
    }

    .news-feed-header h1 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #0d2b4e;
        margin: 0 0 0.25rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .news-feed-header p {
        font-size: 0.875rem;
        color: #6b7280;
        margin: 0;
    }

    /* ── Search Bar ── */
    .feed-search-bar {
        display: flex;
        gap: 0.5rem;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 1.75rem;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 0.75rem 1rem;
        box-shadow: 0 1px 4px rgba(0,0,0,0.05);
    }

    .feed-search-bar input[type="text"] {
        flex: 1;
        min-width: 200px;
        border: none;
        outline: none;
        font-size: 0.9rem;
        font-family: inherit;
        color: #111827;
        background: transparent;
    }

    .feed-search-bar input[type="text"]::placeholder { color: #9ca3af; }

    .feed-search-icon { color: #9ca3af; flex-shrink: 0; }

    .btn-feed-search {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.45rem 1rem;
        background: #2563eb;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 0.8125rem;
        font-weight: 600;
        cursor: pointer;
        font-family: inherit;
        transition: opacity 0.15s;
    }

    .btn-feed-search:hover { opacity: 0.88; }

    .btn-feed-clear {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.45rem 0.875rem;
        background: #f3f4f6;
        color: #374151;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        font-size: 0.8125rem;
        font-weight: 500;
        text-decoration: none;
        transition: background 0.15s;
    }

    .btn-feed-clear:hover { background: #e5e7eb; color: #111827; }

    /* ── News Grid ── */
    .news-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 1.25rem;
    }

    /* ── News Card ── */
    .news-feed-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        display: flex;
        flex-direction: column;
        gap: 0;
        transition: box-shadow 0.2s ease, transform 0.2s ease, border-color 0.2s;
        position: relative;
        overflow: hidden;
    }

    .news-feed-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: linear-gradient(90deg, #2563eb, #60a5fa);
        opacity: 0;
        transition: opacity 0.2s ease;
    }

    .news-feed-card:hover {
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
        transform: translateY(-2px);
        border-color: #bfdbfe;
    }

    .news-feed-card:hover::before { opacity: 1; }

    /* Category pill on card */
    .card-category {
        display: inline-flex;
        align-items: center;
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 999px;
        padding: 0.2rem 0.65rem;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
        width: fit-content;
    }

    /* Card title */
    .card-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: #0d2b4e;
        text-decoration: none;
        line-height: 1.35;
        display: block;
        margin-bottom: 0.5rem;
        transition: color 0.15s;
    }

    .card-title:hover { color: #1d4ed8; }

    /* Card headline */
    .card-headline {
        font-size: 0.875rem;
        color: #6b7280;
        line-height: 1.5;
        margin-bottom: 1rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Card meta */
    .card-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        font-size: 0.78rem;
        color: #9ca3af;
        margin-bottom: 1rem;
        margin-top: auto;
        padding-top: 0.75rem;
        border-top: 1px solid #f3f4f6;
    }

    .card-meta-item {
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .card-meta-item svg { flex-shrink: 0; }

    /* Tags on card */
    .card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
        margin-bottom: 1rem;
    }

    .card-tag {
        background: #f3f4f6;
        color: #374151;
        border-radius: 5px;
        padding: 0.15rem 0.5rem;
        font-size: 0.72rem;
        font-weight: 500;
    }

    /* Read more link */
    .card-read-more {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        color: #2563eb;
        font-size: 0.8125rem;
        font-weight: 600;
        text-decoration: none;
        transition: gap 0.15s;
    }

    .card-read-more:hover { gap: 0.5rem; }

    /* ── Empty state ── */
    .feed-empty {
        text-align: center;
        padding: 5rem 2rem;
        color: #9ca3af;
        background: #fff;
        border-radius: 14px;
        border: 1px dashed #e5e7eb;
    }

    .feed-empty svg { margin-bottom: 1rem; opacity: 0.35; }
    .feed-empty h3 { font-size: 1.1rem; color: #6b7280; margin: 0 0 0.5rem; }
    .feed-empty p { font-size: 0.875rem; margin: 0; }

    @@media (max-width: 640px) {
        .news-grid { grid-template-columns: 1fr; }
    }
</style>
}

<!-- Realtime toast -->
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999">
    <div id="guestRealtimeToast" class="toast" role="status" aria-live="polite" aria-atomic="true">
        <div class="toast-body d-flex align-items-center gap-2 bg-dark text-white rounded">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            News has been updated.
        </div>
    </div>
</div>

<!-- Page Header -->
<div class="news-feed-header">
    <h1>
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 0-1.5 2z"/><path d="M9 7h10M9 11h10M9 15h6"/>
        </svg>
        Active News
    </h1>
    <p>Browse the latest published articles from FPT University</p>
</div>

<!-- Search Bar -->
<form method="get" class="feed-search-bar">
    <svg class="feed-search-icon" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input asp-for="SearchTerm" type="text" placeholder="Search by title, headline or content…" autocomplete="off" />
    <button type="submit" class="btn-feed-search">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        Search
    </button>
    @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
    {
        <a asp-page="/News/Index" class="btn-feed-clear">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
            Clear
        </a>
    }
</form>

<!-- Empty state (shown when no articles, toggled by SignalR) -->
<div id="emptyState" class="feed-empty" style="@(Model.Articles.Count == 0 ? "" : "display:none")">
    <svg width="52" height="52" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
        <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 0-1.5 2z"/><path d="M9 7h10M9 11h10M9 15h6"/>
    </svg>
    <h3>No articles found</h3>
    <p>@(string.IsNullOrWhiteSpace(Model.SearchTerm) ? "There are no active news articles at the moment." : $"No results for \"{Model.SearchTerm}\".")</p>
</div>

<!-- Articles Grid -->
<div id="newsGrid" class="news-grid" style="@(Model.Articles.Count == 0 ? "display:none" : "")">
    @foreach (var article in Model.Articles)
    {
        <article class="news-feed-card" data-id="@article.NewsArticleID">
            <!-- Category -->
            <span class="card-category">@(article.Category?.CategoryName ?? "Uncategorized")</span>

            <!-- Title -->
            <a class="card-title" asp-page="/News/Details" asp-route-id="@article.NewsArticleID">
                @article.NewsTitle
            </a>

            <!-- Headline -->
            <p class="card-headline">@article.Headline</p>

            <!-- Tags -->
            @{
                var tags = article.NewsTags.Where(nt => nt.Tag != null).ToList();
            }
            @if (tags.Any())
            {
                <div class="card-tags">
                    @foreach (var nt in tags)
                    {
                        <span class="card-tag">@nt.Tag!.TagName</span>
                    }
                </div>
            }

            <!-- Meta info -->
            <div class="card-meta">
                <span class="card-meta-item">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                    @article.CreatedDate?.ToString("dd/MM/yyyy HH:mm")
                </span>
                @if (!string.IsNullOrWhiteSpace(article.NewsSource))
                {
                    <span class="card-meta-item">
                        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
                            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                        </svg>
                        @article.NewsSource
                    </span>
                }
            </div>

            <!-- Read more -->
            <a class="card-read-more" asp-page="/News/Details" asp-route-id="@article.NewsArticleID">
                Read more
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
            </a>
        </article>
    }
</div>

@section Scripts {
    <script src="~/js/newsHubClient.js" asp-append-version="true"></script>
    <script>
    (() => {
        if (!window.newsHub) return;

        const esc = s => (s ?? '').toString()
            .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;').replace(/'/g, '&#39;');

        function buildCard(p) {
            const tags = (p.tagNames && p.tagNames.length)
                ? p.tagNames.map(t => `<span class="card-tag">${esc(t)}</span>`).join('')
                : '';
            const tagsHtml = tags ? `<div class="card-tags">${tags}</div>` : '';
            const sourceHtml = p.source ? `
                <span class="card-meta-item">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                    </svg>
                    ${esc(p.source)}
                </span>` : '';

            return `
            <article class="news-feed-card" data-id="${esc(p.id)}" style="animation:fadeIn .3s ease">
                <span class="card-category">${esc(p.category)}</span>
                <a class="card-title" href="/News/Details/${encodeURIComponent(p.id)}">${esc(p.title)}</a>
                <p class="card-headline">${esc(p.headline)}</p>
                ${tagsHtml}
                <div class="card-meta">
                    <span class="card-meta-item">
                        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                        ${esc(p.created)}
                    </span>
                    ${sourceHtml}
                </div>
                <a class="card-read-more" href="/News/Details/${encodeURIComponent(p.id)}">
                    Read more
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                        <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                    </svg>
                </a>
            </article>`;
        }

        function showToast(msg) {
            const el = document.getElementById('guestRealtimeToast');
            if (!el || !window.bootstrap) return;
            el.querySelector('.toast-body').textContent = msg;
            bootstrap.Toast.getOrCreateInstance(el, { delay: 3000 }).show();
        }

        function syncEmptyState() {
            const grid = document.getElementById('newsGrid');
            const empty = document.getElementById('emptyState');
            if (!grid || !empty) return;
            const hasCards = grid.querySelectorAll('article[data-id]').length > 0;
            grid.style.display = hasCards ? '' : 'none';
            empty.style.display = hasCards ? 'none' : '';
        }

        window.newsHub.subscribe(payload => {
            const grid = document.getElementById('newsGrid');
            if (!grid) return;

            const existing = grid.querySelector(`article[data-id="${payload.id}"]`);

            if (payload.action === 'deleted') {
                if (existing) { existing.remove(); showToast('An article has been removed.'); }
            } else if (payload.status) {
                // active article — add or update
                if (existing) {
                    existing.outerHTML = buildCard(payload);
                    showToast('An article has been updated.');
                } else {
                    grid.insertAdjacentHTML('afterbegin', buildCard(payload));
                    showToast('A new article has been published!');
                }
            } else {
                // article turned inactive — remove from guest view
                if (existing) { existing.remove(); showToast('An article has been updated.'); }
            }

            syncEmptyState();
        });

        // Add fade-in keyframe once
        if (!document.getElementById('guestRealtimeStyle')) {
            const s = document.createElement('style');
            s.id = 'guestRealtimeStyle';
            s.textContent = '@@keyframes fadeIn { from { opacity:0; transform:translateY(-8px); } to { opacity:1; transform:translateY(0); } }';
            document.head.appendChild(s);
        }

        // Fallback for an unavailable SignalR connection. It remains active
        // while searching too, so a guest never needs to submit Search or F5.
        {
            setInterval(async () => {
                try {
                    const resp = await fetch(window.location.pathname + '?handler=Articles', {
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    if (!resp.ok) return;
                    const articles = await resp.json();
                    if (!Array.isArray(articles)) return;

                    const grid = document.getElementById('newsGrid');
                    if (!grid) return;

                    // Add new articles that aren't in the grid yet
                    articles.forEach(p => {
                        const exists = grid.querySelector(`article[data-id="${esc(p.id)}"]`);
                        if (!exists && p.status) {
                            grid.insertAdjacentHTML('afterbegin', buildCard(p));
                        }
                    });

                    // Remove articles no longer in list
                    grid.querySelectorAll('article[data-id]').forEach(card => {
                        const id = card.dataset.id;
                        const stillExists = articles.some(a => a.id === id && a.status);
                        if (!stillExists) card.remove();
                    });

                    syncEmptyState();
                } catch (e) { /* silent fail */ }
            }, 3000);
        }
    })();
    </script>
}
