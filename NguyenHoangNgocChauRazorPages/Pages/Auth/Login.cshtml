@page "/"
@model NguyenHoangNgocChauRazorPages.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        /* ── Login Page Overrides ── */
        body.login-page {
            background: linear-gradient(135deg, #0d2b4e 0%, #1a4a7a 45%, #0f3d66 100%);
            min-height: 100vh;
        }

        body.login-page header {
            display: none;
        }

        body.login-page main.container {
            max-width: 100%;
            margin: 0;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        /* ── Card ── */
        .login-wrapper {
            width: 100%;
            max-width: 460px;
            padding: 1.5rem;
            margin: 0 auto;
        }

        .login-card {
            background: rgba(255, 255, 255, 0.97);
            border-radius: 20px;
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.35), 0 8px 20px rgba(0, 0, 0, 0.15);
            padding: 3rem 2.75rem 2.5rem;
            position: relative;
            overflow: hidden;
        }

        .login-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 5px;
            background: linear-gradient(90deg, #1a56db, #3b82f6, #60a5fa);
        }

        /* ── Brand / Header ── */
        .login-brand {
            text-align: center;
            margin-bottom: 2rem;
        }

        .login-brand .brand-icon {
            width: 64px;
            height: 64px;
            background: linear-gradient(135deg, #1a56db, #3b82f6);
            border-radius: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1rem;
            box-shadow: 0 8px 20px rgba(26, 86, 219, 0.35);
        }

        .login-brand .brand-icon svg {
            width: 32px;
            height: 32px;
            fill: white;
        }

        .login-brand h1 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #0d2b4e;
            letter-spacing: -0.3px;
            margin: 0 0 0.25rem;
        }

        .login-brand p {
            font-size: 0.875rem;
            color: #6b7280;
            margin: 0;
        }

        /* ── Form Controls ── */
        .form-label-custom {
            font-size: 0.8125rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 0.4rem;
            display: block;
            letter-spacing: 0.02em;
            text-transform: uppercase;
        }

        .input-icon-wrapper {
            position: relative;
        }

        .input-icon-wrapper .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            pointer-events: none;
            transition: color 0.2s ease;
            display: flex;
            align-items: center;
        }

        .input-icon-wrapper .input-icon svg {
            width: 18px;
            height: 18px;
        }

        .input-custom {
            width: 100%;
            padding: 0.7rem 0.875rem 0.7rem 2.75rem;
            border: 1.5px solid #e5e7eb;
            border-radius: 10px;
            font-size: 0.9375rem;
            color: #111827;
            background: #f9fafb;
            transition: border-color 0.22s ease, background 0.22s ease, box-shadow 0.22s ease;
            outline: none;
            font-family: inherit;
        }

        .input-custom:focus {
            border-color: #1a56db;
            background: #ffffff;
            box-shadow: 0 0 0 4px rgba(26, 86, 219, 0.1);
        }

        .input-icon-wrapper:focus-within .input-icon {
            color: #1a56db;
        }

        /* ── Validation ── */
        .login-alert {
            display: flex;
            align-items: flex-start;
            gap: 0.625rem;
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-left: 4px solid #ef4444;
            border-radius: 10px;
            padding: 0.75rem 1rem;
            margin-bottom: 1.25rem;
            font-size: 0.875rem;
            color: #b91c1c;
        }

        .login-alert svg {
            width: 18px;
            height: 18px;
            flex-shrink: 0;
            margin-top: 1px;
        }

        .field-error {
            font-size: 0.78rem;
            color: #dc2626;
            margin-top: 0.3rem;
            display: flex;
            align-items: center;
            gap: 0.25rem;
        }

        /* ── Submit Button ── */
        .btn-login {
            width: 100%;
            padding: 0.8rem;
            background: linear-gradient(135deg, #1a56db, #2563eb);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 0.9375rem;
            font-weight: 600;
            letter-spacing: 0.01em;
            cursor: pointer;
            transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.2s ease;
            box-shadow: 0 4px 14px rgba(26, 86, 219, 0.4);
            font-family: inherit;
            margin-top: 0.5rem;
        }

        .btn-login:hover {
            background: linear-gradient(135deg, #1748c4, #1d4ed8);
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(26, 86, 219, 0.5);
        }

        .btn-login:active {
            transform: translateY(0);
            box-shadow: 0 2px 8px rgba(26, 86, 219, 0.35);
        }

        /* ── Guest Link ── */
        .login-footer {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.875rem;
            color: #6b7280;
        }

        .login-footer a {
            color: #1a56db;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.15s ease;
        }

        .login-footer a:hover {
            color: #1248b8;
            text-decoration: underline;
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin: 1.5rem 0 1.25rem;
            color: #d1d5db;
            font-size: 0.75rem;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            border-top: 1px solid #e5e7eb;
        }
    </style>
}

<script>
    document.body.classList.add('login-page');
</script>

<div class="login-wrapper">
    <div class="login-card">

        <!-- Brand Header -->
        <div class="login-brand">
            <div class="brand-icon">
                <!-- Newspaper / News icon -->
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2zm-7 14H7v-2h5v2zm5-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                </svg>
            </div>
            <h1>FUNews Management</h1>
            <p>Sign in to your account to continue</p>
        </div>

        <!-- Login Form -->
        <form method="post" id="login-form">
            <!-- Validation Summary (model-level errors like invalid credentials) -->
            <div id="val-summary-alert" class="login-alert" style="display:none" role="alert" aria-live="polite">
                <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                </svg>
                <div asp-validation-summary="ModelOnly"></div>
            </div>

            <!-- Email Field -->
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label-custom"></label>
                <div class="input-icon-wrapper">
                    <span class="input-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                    </span>
                    <input asp-for="Input.Email"
                           class="input-custom"
                           autocomplete="email"
                           placeholder="you@fu.edu.vn"
                           id="Input_Email" />
                </div>
                <span asp-validation-for="Input.Email" class="field-error"></span>
            </div>

            <!-- Password Field -->
            <div class="mb-4">
                <label asp-for="Input.Password" class="form-label-custom"></label>
                <div class="input-icon-wrapper">
                    <span class="input-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                    </span>
                    <input asp-for="Input.Password"
                           class="input-custom"
                           autocomplete="current-password"
                           placeholder="••••••••"
                           id="Input_Password" />
                </div>
                <span asp-validation-for="Input.Password" class="field-error"></span>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn-login" id="btn-login">
                Sign In
            </button>
        </form>

        <!-- Divider + Guest Link -->
        <div class="divider">or</div>
        <div class="login-footer">
            <p class="mb-0">
                <a asp-page="/News/Index" id="link-guest">
                    Continue as guest &rarr;
                </a>
            </p>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.21.0/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
    <script>
        // Show the styled alert box if the server returned model-level errors
        (function () {
            var alertBox = document.getElementById('val-summary-alert');
            if (alertBox) {
                // asp-validation-summary renders a <ul> only when there are errors
                var ul = alertBox.querySelector('ul');
                if (ul && ul.children.length > 0) {
                    alertBox.style.display = 'flex';
                }
            }
        })();
    </script>
}
