@page
@model NguyenHoangNgocChauRazorPages.Pages.Staff.News.IndexModel
@{
    ViewData["Title"] = "News Management";
    Layout = "_StaffLayout";
}
@section Styles {
<style>
    /* ── Page Header ── */
    .dash-header {
        display: flex; align-items: center; justify-content: space-between;
        gap: 1rem; flex-wrap: wrap; margin-bottom: 1.25rem;
    }
    .page-title {
        font-size: 1.4rem; font-weight: 700; color: #0d2b4e; margin: 0;
        display: flex; align-items: center; gap: 0.55rem;
    }
    .page-title svg { color: #2563eb; }

    .btn-create {
        display: inline-flex; align-items: center; gap: 0.4rem;
        padding: 0.55rem 1.25rem;
        background: linear-gradient(135deg, #1a56db, #2563eb);
        color: #fff; border: none; border-radius: 10px;
        font-size: 0.875rem; font-weight: 600; cursor: pointer;
        text-decoration: none; transition: opacity 0.18s, transform 0.15s, box-shadow 0.18s;
        box-shadow: 0 3px 10px rgba(26,86,219,0.35);
    }
    .btn-create:hover { opacity: 0.92; transform: translateY(-1px); color: #fff; box-shadow: 0 5px 16px rgba(26,86,219,0.45); }

    /* ── Search Bar ── */
    .news-search-bar {
        display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;
        margin-bottom: 1.25rem; background: #fff; border: 1px solid #e5e7eb;
        border-radius: 12px; padding: 0.6rem 0.875rem; box-shadow: 0 1px 4px rgba(0,0,0,0.05);
    }
    .news-search-bar .search-icon { color: #9ca3af; flex-shrink: 0; }
    .news-search-bar input[type="text"] {
        flex: 1; min-width: 200px; border: none; outline: none;
        font-size: 0.9rem; color: #111827; background: transparent;
    }
    .news-search-bar input[type="text"]::placeholder { color: #9ca3af; }

    /* ── Professional Table ── */
    .news-table-card { border-radius: 14px; overflow: hidden; }
    .news-table { font-size: 0.875rem; }
    .news-table thead th {
        background: #f8fafc;
        font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.05em; color: #6b7280;
        border-bottom: 1px solid #e5e7eb; padding: 0.8rem 1rem; white-space: nowrap;
    }
    .news-table tbody td { padding: 0.85rem 1rem; border-color: #f3f4f6; }
    .news-title {
        font-weight: 600; color: #0d2b4e; max-width: 240px;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .news-headline {
        max-width: 240px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .cat-badge { background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; font-weight: 500; }
    .tag-cell { max-width: 210px; }

    /* ══════════════════════════════════════════
       MODALS — keep IDs & structure intact
    ══════════════════════════════════════════ */
    #newsModal .modal-content,
    #deleteModal .modal-content {
        border: none; border-radius: 16px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.2); overflow: hidden;
    }
    #newsModal .modal-header {
        background: linear-gradient(135deg, #0d2b4e, #1a4a7a);
        color: #fff; border-bottom: none; padding: 1.25rem 1.5rem;
    }
    #newsModal .modal-title { font-size: 1rem; font-weight: 700; display: flex; align-items: center; gap: 0.5rem; }
    #newsModal .btn-close { filter: invert(1) grayscale(1) brightness(2); opacity: 0.8; }
    #newsModal .modal-body { padding: 1.5rem; }
    #newsModal .modal-footer { padding: 1rem 1.5rem; background: #f8fafc; border-top: 1px solid #e5e7eb; }
    #newsModal .form-label {
        font-size: 0.8rem; font-weight: 600; color: #374151;
        text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 0.35rem;
    }
    #newsModal .form-control, #newsModal .form-select {
        border: 1.5px solid #e5e7eb; border-radius: 9px; font-size: 0.9rem;
        background: #f9fafb; color: #111827; padding: 0.55rem 0.875rem;
    }
    #newsModal .form-control:focus, #newsModal .form-select:focus {
        border-color: #2563eb; background: #fff; box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
    }
    #newsModal .input-validation-error { border-color: #ef4444; background: #fff5f5; }
    #newsModal .field-validation-error { font-size: 0.78rem; color: #dc2626; margin-top: 0.25rem; display: block; }
    #newsModal [data-valmsg-summary] ul, #newsModal .text-danger:not(span) {
        background: #fef2f2; border: 1px solid #fecaca; border-left: 4px solid #ef4444;
        border-radius: 9px; padding: 0.75rem 1rem; margin-bottom: 1rem;
        font-size: 0.875rem; color: #b91c1c; list-style: none;
    }
    #newsModal .form-check-input { width: 2.5rem; height: 1.35rem; cursor: pointer; }
    .modal-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 0 1rem; }
    #newsModal select[multiple] { height: 120px; }

    .btn-modal-cancel {
        display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.55rem 1.25rem;
        background: #f3f4f6; color: #374151; border: 1px solid #e5e7eb; border-radius: 9px;
        font-size: 0.875rem; font-weight: 600; cursor: pointer;
    }
    .btn-modal-cancel:hover { background: #e5e7eb; }
    .btn-modal-save {
        display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.55rem 1.5rem;
        background: linear-gradient(135deg, #1a56db, #2563eb); color: #fff; border: none;
        border-radius: 9px; font-size: 0.875rem; font-weight: 600; cursor: pointer;
        box-shadow: 0 2px 8px rgba(26,86,219,0.35);
    }
    .btn-modal-save:hover { opacity: 0.9; transform: translateY(-1px); }

    #deleteModal .modal-content { text-align: center; }
    #deleteModal .modal-body { padding: 2.5rem 2rem 1.5rem; }
    .delete-icon-wrap {
        width: 72px; height: 72px; background: #fef2f2; border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem;
    }
    .delete-icon-wrap svg { color: #ef4444; }
    #deleteModal h5 { font-size: 1.1rem; font-weight: 700; color: #111827; margin-bottom: 0.5rem; }
    #deleteModal p { font-size: 0.875rem; color: #6b7280; margin-bottom: 0; }
    #deleteModal .modal-footer { border-top: 1px solid #f3f4f6; padding: 1rem 1.5rem; display: flex; justify-content: center; gap: 0.75rem; background: #f8fafc; }
    .btn-confirm-delete {
        display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.55rem 1.5rem;
        background: #ef4444; color: #fff; border: none; border-radius: 9px;
        font-size: 0.875rem; font-weight: 600; cursor: pointer; box-shadow: 0 2px 8px rgba(239,68,68,0.3);
    }
    .btn-confirm-delete:hover { opacity: 0.9; transform: translateY(-1px); }

    @@media (max-width: 640px) {
        .modal-grid-2 { grid-template-columns: 1fr; }
    }
</style>
}


<!-- SignalR realtime toast (kept) -->
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999">
    <div id="newsRealtimeToast" class="toast" role="status" aria-live="polite" aria-atomic="true">
        <div class="toast-body d-flex align-items-center gap-2 bg-dark text-white rounded">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            News list has been updated.
        </div>
    </div>
</div>


<!-- Header -->
<div class="dash-header">
    <h1 class="page-title">
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 0-1.5 2z"/><path d="M9 7h10M9 11h10M9 15h6"/></svg>
        News Management
    </h1>
    <button class="btn-create" type="button" onclick="openCreateModal()">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Create News
    </button>
</div>

<!-- Flash alerts -->
@if (TempData["Success"] is string success)
{
    <div class="alert alert-success d-flex align-items-center gap-2 border-0 shadow-sm" role="alert">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
        @success
    </div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger d-flex align-items-center gap-2 border-0 shadow-sm" role="alert">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        @error
    </div>
}

<!-- Search -->
<form method="get" class="news-search-bar">
    <svg class="search-icon" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input asp-for="SearchTerm" type="text" placeholder="Search by title, headline or content…" autocomplete="off" />
    <button type="submit" class="btn btn-primary btn-sm px-3">Search</button>
    <a asp-page="/Staff/News/Index" class="btn btn-light btn-sm px-3 border">Clear</a>
</form>

<!-- Table -->
<div class="card border-0 shadow-sm news-table-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle news-table mb-0">
            <thead>
                <tr>
                    <th>Article</th>
                    <th>Category</th>
                    <th>Created</th>
                    <th>Status</th>
                    <th>Tags</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody id="newsTableBody">
                @if (!Model.Articles.Any())
                {
                    <tr id="emptyRow">
                        <td colspan="6" class="text-center text-muted py-5">No news articles found.</td>
                    </tr>
                }
                @foreach (var article in Model.Articles)
                {
                    <tr data-row-id="@article.NewsArticleID">
                        <td>
                            <div class="news-title">@article.NewsTitle</div>
                            <div class="news-headline text-muted small">@article.Headline</div>
                        </td>
                        <td><span class="badge rounded-pill cat-badge">@(article.Category?.CategoryName ?? "N/A")</span></td>
                        <td class="text-muted small text-nowrap">@article.CreatedDate?.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (article.NewsStatus == true)
                            {
                                <span class="badge rounded-pill text-bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill text-bg-warning">Inactive</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex flex-wrap gap-1 tag-cell">
                                @foreach (var nt in article.NewsTags.Where(x => x.Tag != null))
                                {
                                    <span class="badge rounded-pill text-bg-light border fw-normal">@nt.Tag!.TagName</span>
                                }
                                @if (!article.NewsTags.Any(x => x.Tag != null))
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </div>
                        </td>
                        <td class="text-end text-nowrap">
                            <button type="button" class="btn btn-sm btn-outline-primary me-1" onclick="openEditModal(this)"
                                    data-id="@article.NewsArticleID"
                                    data-title="@article.NewsTitle"
                                    data-headline="@article.Headline"
                                    data-content="@article.NewsContent"
                                    data-source="@article.NewsSource"
                                    data-category="@article.CategoryID"
                                    data-status="@article.NewsStatus.GetValueOrDefault().ToString().ToLowerInvariant()"
                                    data-state="@article.ArticleStateID"
                                    data-tags="@string.Join(',', article.NewsTags.Select(x => x.TagID))">
                                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                Edit
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="openDeleteModal('@article.NewsArticleID')">
                                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                                Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


<!-- ══════════════ CREATE / EDIT MODAL (intact) ══════════════ -->
<div class="modal fade" id="newsModal" tabindex="-1" aria-labelledby="modalTitle" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <form id="newsForm" method="post" asp-page-handler="Save">

                <div class="modal-header">
                    <h5 id="modalTitle" class="modal-title">
                        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 0-1.5 2z"/></svg>
                        News
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">

                    <input asp-for="Input.NewsArticleID" type="hidden" />
                    <input asp-for="Input.ArticleStateID" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="modal-grid-2">
                        <div class="mb-3">
                            <label asp-for="Input.NewsTitle" class="form-label"></label>
                            <input asp-for="Input.NewsTitle" class="form-control" placeholder="Enter news title…" />
                            <span asp-validation-for="Input.NewsTitle" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.Headline" class="form-label"></label>
                            <input asp-for="Input.Headline" class="form-control" placeholder="Short headline…" />
                            <span asp-validation-for="Input.Headline" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.NewsContent" class="form-label"></label>
                        <textarea asp-for="Input.NewsContent" class="form-control" rows="5" placeholder="Write the full article content…"></textarea>
                        <span asp-validation-for="Input.NewsContent" class="text-danger"></span>
                    </div>

                    <div class="modal-grid-2">
                        <div class="mb-3">
                            <label asp-for="Input.NewsSource" class="form-label"></label>
                            <input asp-for="Input.NewsSource" class="form-control" placeholder="Source URL or name…" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.CategoryID" class="form-label"></label>
                            <select asp-for="Input.CategoryID" class="form-select">
                                <option value="0">-- Select category --</option>
                                @foreach (var category in Model.Categories)
                                {
                                    <option value="@category.CategoryID">@category.CategoryName</option>
                                }
                            </select>
                            <span asp-validation-for="Input.CategoryID" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.TagIDs" class="form-label"></label>
                        <select asp-for="Input.TagIDs" class="form-select" multiple>
                            @foreach (var tag in Model.Tags)
                            {
                                <option value="@tag.TagID">@tag.TagName</option>
                            }
                        </select>
                        <div style="font-size:0.75rem;color:#9ca3af;margin-top:0.3rem">Hold Ctrl / Cmd to select multiple tags</div>
                    </div>

                    <div class="form-check form-switch">
                        <input asp-for="Input.NewsStatus" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="Input.NewsStatus" class="form-check-label"></label>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-modal-cancel" data-bs-dismiss="modal">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        Cancel
                    </button>
                    <button type="button" id="saveBtn" class="btn-modal-save" onclick="saveArticle()">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                        <span id="saveBtnText">Save Article</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>


<!-- ══════════════ DELETE CONFIRM MODAL (intact) ══════════════ -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px">
        <div class="modal-content">
            <div class="modal-body">
                <div class="delete-icon-wrap">
                    <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                        <polyline points="3 6 5 6 21 6"/>
                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                        <path d="M10 11v6M14 11v6"/>
                        <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                    </svg>
                </div>
                <h5>Delete Article?</h5>
                <p>This action cannot be undone. The article will be permanently removed.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-modal-cancel" data-bs-dismiss="modal">Cancel</button>
                <input type="hidden" id="deleteArticleId" value="" />
                <button type="button" id="confirmDeleteBtn" class="btn-confirm-delete" onclick="confirmDelete()">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                    <span id="deleteBtnText">Yes, Delete</span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {

    <script src="~/js/newsHubClient.js" asp-append-version="true"></script>
    <script src="~/js/newsRealtime.js" asp-append-version="true"></script>

    <script>
        const newsModal  = new bootstrap.Modal(document.getElementById('newsModal'));
        const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
        const e = id => document.getElementById(id);

        /* ── Tag selector helper ── */
        function setTags(value) {
            const chosen = value ? value.split(',') : [];
            Array.from(e('Input_TagIDs').options).forEach(o => o.selected = chosen.includes(o.value));
        }

        /* ── Toast helper ── */
        function showPageToast(msg, ok) {
            const el = e('newsRealtimeToast');
            if (!el) return;
            el.querySelector('.toast-body').textContent = msg;
            el.className = `toast ${ok ? 'bg-success' : 'bg-danger'} text-white`;
            bootstrap.Toast.getOrCreateInstance(el, { delay: 3000 }).show();
        }

        /* ── Validation error helpers ── */
        function clearModalErrors() {
            const summary = document.querySelector('#newsModal [data-valmsg-summary]');
            if (summary) { summary.style.display = 'none'; summary.querySelector('ul')?.replaceChildren(); }
        }

        function showModalErrors(errors) {
            const summary = document.querySelector('#newsModal [data-valmsg-summary]');
            if (!summary) return;
            summary.style.display = '';
            const ul = summary.querySelector('ul') ?? summary.appendChild(document.createElement('ul'));
            ul.replaceChildren();
            (errors || []).forEach(msg => { const li = document.createElement('li'); li.textContent = msg; ul.appendChild(li); });
        }

        /* ── Open modals ── */
        function openCreateModal() {
            clearModalErrors();
            e('modalTitle').textContent = 'Create News Article';
            e('Input_NewsArticleID').value = '';
            e('Input_NewsTitle').value = '';
            e('Input_Headline').value = '';
            e('Input_NewsContent').value = '';
            e('Input_NewsSource').value = '';
            e('Input_CategoryID').value = '0';
            e('Input_NewsStatus').checked = true;
            e('Input_ArticleStateID').value = '3';
            setTags('');
            newsModal.show();
        }

        function openEditModal(button) {
            clearModalErrors();
            const d = button.dataset;
            e('modalTitle').textContent = 'Edit News Article';
            e('Input_NewsArticleID').value = d.id;
            e('Input_NewsTitle').value = d.title;
            e('Input_Headline').value = d.headline;
            e('Input_NewsContent').value = d.content;
            e('Input_NewsSource').value = d.source;
            e('Input_CategoryID').value = d.category;
            e('Input_NewsStatus').checked = d.status === 'true';
            e('Input_ArticleStateID').value = d.state;
            setTags(d.tags);
            newsModal.show();
        }

        function openDeleteModal(articleId) {
            e('deleteArticleId').value = articleId;
            deleteModal.show();
        }

        /* ── AJAX Save ── */
        async function saveArticle() {
            const btn = e('saveBtn');
            const btnText = e('saveBtnText');
            btn.disabled = true;
            btnText.textContent = 'Saving…';
            clearModalErrors();

            try {
                const form = e('newsForm');
                const formData = new FormData(form);

                const resp = await fetch(form.action, {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: formData
                });

                if (resp.status === 401) {
                    showModalErrors(['Your session has expired. Please sign in again.']);
                    return;
                }
                if (!resp.ok) {
                    throw new Error(`Save failed with status ${resp.status}`);
                }
                const data = await resp.json();
                if (data.success) {
                    newsModal.hide();
                    showPageToast(data.message, true);
                    // Update this tab immediately, even while the hub reconnects.
                    await window.refreshStaffNews?.();
                } else {
                    showModalErrors(data.errors || [data.message]);
                }
            } catch (err) {
                showModalErrors(['An unexpected error occurred. Please try again.']);
                console.error('Save error:', err);
            } finally {
                btn.disabled = false;
                btnText.textContent = 'Save Article';
            }
        }

        /* ── AJAX Delete ── */
        async function confirmDelete() {
            const btn = e('confirmDeleteBtn');
            const btnText = e('deleteBtnText');
            const articleId = e('deleteArticleId').value;
            btn.disabled = true;
            btnText.textContent = 'Deleting…';

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                const resp = await fetch('?handler=Delete', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: `id=${encodeURIComponent(articleId)}&__RequestVerificationToken=${encodeURIComponent(token)}`
                });

                if (resp.status === 401) {
                    throw new Error('Your session has expired. Please sign in again.');
                }
                if (!resp.ok) {
                    throw new Error(`Delete failed with status ${resp.status}`);
                }
                const data = await resp.json();
                deleteModal.hide();
                if (data.success) {
                    // Immediately remove the row from DOM with fade
                    const row = document.querySelector(`tr[data-row-id="${articleId}"]`);
                    if (row) {
                        row.style.transition = 'opacity 0.3s, transform 0.3s';
                        row.style.opacity = '0';
                        row.style.transform = 'translateX(20px)';
                        setTimeout(() => {
                            row.remove();
                            const tbody = document.getElementById('newsTableBody');
                            if (tbody && !tbody.querySelector('tr[data-row-id]')) {
                                tbody.innerHTML = '<tr id="emptyRow"><td colspan="6" class="text-center text-muted py-5">No news articles found.</td></tr>';
                            }
                        }, 300);
                    }
                    showPageToast(data.message, true);
                } else {
                    showPageToast(data.message, false);
                }
            } catch (err) {
                showPageToast('An unexpected error occurred.', false);
                console.error('Delete error:', err);
            } finally {
                btn.disabled = false;
                btnText.textContent = 'Yes, Delete';
            }
        }
    </script>
}
